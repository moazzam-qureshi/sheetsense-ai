# =============================================================================
# SheetSense AI — environment variables
# =============================================================================
# Copy this file to .env and fill in real values.
# Never commit .env — it's gitignored.
# In production (Coolify), paste these into the project's env panel.
# =============================================================================

# -----------------------------------------------------------------------------
# Public URLs (NEXT_PUBLIC_* are baked into the web bundle at build time —
# rebuild the web image after changing these, restart alone is not enough)
# -----------------------------------------------------------------------------
# Coolify-assigned web domain (e.g. https://abc.65.108.2.94.sslip.io). In local
# dev set to http://localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Coolify-assigned Mastra service domain. In local dev set to http://localhost:4111.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4111

# -----------------------------------------------------------------------------
# LLM provider (OpenRouter)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=

# Models. Locked per docs/architecture.md §6.
LLM_MODEL_SCHEMA=openai/gpt-4o-mini
LLM_MODEL_PLANNER=openai/gpt-4o-mini
LLM_MODEL_ANALYST=openai/gpt-4o
LLM_MODEL_WRITER=openai/gpt-4o-mini

# -----------------------------------------------------------------------------
# Composio (per-visitor OAuth)
# -----------------------------------------------------------------------------
# Account-level API key from app.composio.dev → Settings → API keys.
COMPOSIO_API_KEY=
# Demo user id for the 3 sample sheets (pre-granted access to sheets we own).
# Per-visitor sessions mint their own user ids at runtime; this is the fallback.
COMPOSIO_DEMO_USER_ID=sheetsense_demo
# OAuth callback URL — must exactly match what's registered in Composio's
# dashboard for the Google Sheets + Gmail toolkits.
COMPOSIO_OAUTH_REDIRECT=http://localhost:3000/api/composio/callback

# -----------------------------------------------------------------------------
# Cloudflare Turnstile (mandatory — gates the workflow-run endpoint)
# -----------------------------------------------------------------------------
# Server-side secret (Cloudflare dashboard → Turnstile → site → Secret key).
TURNSTILE_SECRET=
# Client-side sitekey (Cloudflare dashboard → Turnstile → site → Site key).
# IMPORTANT: rebuild web image after changing this (baked at build time).
NEXT_PUBLIC_TURNSTILE_SITEKEY=

# Dev sitekeys (uncomment for local testing, never for production):
#   1x00000000000000000000AA  — always passes silently
#   2x00000000000000000000AB  — always blocks
#   3x00000000000000000000FF  — always shows visible challenge

# -----------------------------------------------------------------------------
# Persistence
# -----------------------------------------------------------------------------
# Postgres for Mastra memory + workflow state + sessions table.
# Local dev: postgresql://sheetsense:sheetsense@localhost:5434/sheetsense
# (port 5434 to avoid colliding with DocuAI on 5433 and any local installs on 5432)
DATABASE_URL=postgresql://sheetsense:sheetsense@localhost:5434/sheetsense

# Redis for sandbox sheet cache, per-IP rate limit, daily cost ceiling.
# Local dev: redis://localhost:6381
# (port 6381 to avoid colliding with DocuAI on 6379)
REDIS_URL=redis://localhost:6381

# -----------------------------------------------------------------------------
# Sandbox sidecar
# -----------------------------------------------------------------------------
# Internal URL from Mastra service to the Python sandbox. In compose, the
# service name resolves: http://sandbox:8001
SANDBOX_URL=http://localhost:8001

# Wall-clock timeout for sandbox subprocess (must exceed RLIMIT_CPU=10).
SANDBOX_TIMEOUT_SEC=6

# -----------------------------------------------------------------------------
# Cost ceiling + rate limit
# -----------------------------------------------------------------------------
# USD/IP/day. Workflow runs are rejected once an IP exceeds this in a 24h window.
PER_IP_DAILY_COST_USD=0.50
# Workflow runs per IP per minute.
PER_IP_RATE_PER_MIN=5

# -----------------------------------------------------------------------------
# Admin
# -----------------------------------------------------------------------------
# Token for the admin endpoint (currently used to upload sample-sheet fixtures
# and to manually trigger cleanup). Bearer token in the Authorization header.
ADMIN_TOKEN=

# -----------------------------------------------------------------------------
# Observability (optional, leave empty to disable)
# -----------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# -----------------------------------------------------------------------------
# Trusted proxy (for X-Forwarded-For anti-spoof)
# -----------------------------------------------------------------------------
# Comma-separated list of trusted upstream IPs. In Coolify this is Traefik's
# internal IP — discover it once via `docker network inspect coolify` and pin
# here. Empty means trust the immediate upstream (insecure, dev only).
TRUSTED_PROXIES=
